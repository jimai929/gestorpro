# Plantilla de entorno de PRODUCCIÓN de GestorPro. Copiar a deploy/.env y
# rellenar. El .env JAMÁS se commitea (permisos 600). deploy.sh y docker-compose
# construyen las URLs de conexión a partir de estas contraseñas.

# --- Dominio y TLS ---
DOMINIO=midominio.com
ACME_EMAIL=tu-correo@ejemplo.com
# IPs de salida de las sedes (separadas por espacio), para la allowlist del
# kiosco en el Caddyfile (gate de P2). Dejar vacío si no se usa.
SEDE_IPS=

# --- Postgres: tres contraseñas distintas y fuertes ---
# IMPORTANTE: van dentro de URLs de conexión (postgresql://user:PASS@host), así
# que SOLO pueden contener caracteres URL-safe: [A-Za-z0-9._-]. NO uses
# @ : / # ? % & ni espacios (romperían la URL). deploy.sh rechaza el despliegue
# si no son URL-safe. Genera cada una con:
#   openssl rand -hex 32
POSTGRES_SUPER_PASSWORD=
GESTORPRO_MIGRADOR_PASSWORD=
GESTORPRO_APP_PASSWORD=

# --- Backend ---
# Generar fuerte, p. ej. (PowerShell):
#   [Convert]::ToBase64String((1..48 | % {Get-Random -Max 256}))
JWT_ACCESS_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DIAS=30
VERIFICADOR_FACIAL=simulado
# Con el verificador simulado DEBE ir en true (todo fichaje a revisión).
FICHAJE_REVISION_TOTAL=true

# --- Admin inicial (solo lo usa el seed, no la app en ejecución) ---
# Personaliza ADMIN_EMAIL a uno real y NO adivinable (no dejes el de ejemplo):
# reduce la superficie de fuerza bruta del login (el lado "usuario").
ADMIN_EMAIL=admin@gestorpro.local
ADMIN_PASSWORD=
