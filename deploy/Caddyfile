# Caddyfile de GestorPro. Dos subdominios (no path-routing: las rutas del backend
# colisionan con las del SPA). TLS automático vía Let's Encrypt. Las variables
# {$DOMINIO}, {$ACME_EMAIL} y {$SEDE_IPS} las inyecta docker-compose desde .env.

{
	email {$ACME_EMAIL}
}

# SPA (frontend estático). Imagen construida con VITE_API_URL=https://api.<dominio>.
app.{$DOMINIO} {
	root * /srv/www
	encode gzip
	try_files {path} /index.html
	file_server
}

# API (backend Fastify). El mismo binario sirve finanzas y asistencia.
api.{$DOMINIO} {
	reverse_proxy backend:3000

	# --- Allowlist de IPs del kiosco (gate de P2) -----------------------------
	# Restringe la superficie PÚBLICA del kiosco a las IPs de salida de las sedes
	# (defensa en profundidad SOBRE el token de dispositivo, que ya es obligatorio).
	#
	# OJO con Caddy v2: el matcher 'path' es EXACTO (no por prefijo) y las rutas del
	# backend no llevan prefijo. La superficie pública del kiosco son SOLO
	# POST /fichajes (fichaje del dispositivo) y GET /kioscos (catálogo de
	# descubrimiento). Los endpoints de ADMIN — POST /kioscos y POST /kioscos/:id/token
	# — van protegidos por JWT y NO deben filtrarse por IP (el admin trabaja desde
	# cualquier sitio): por eso se filtra por MÉTODO además de por ruta. (GET
	# /fichajes/cola-revision también es admin/JWT y, al ser otra ruta, no entra aquí.)
	#
	# Para activarlo: define SEDE_IPS en deploy/.env (IPs separadas por espacio) y
	# descomenta los DOS bloques. Si una sede no tiene IP fija, déjalo comentado: el
	# token de dispositivo sigue protegiendo el fichaje.
	#
	# @fichaje_fuera_de_sede {
	# 	method POST
	# 	path /fichajes
	# 	not remote_ip {$SEDE_IPS}
	# }
	# respond @fichaje_fuera_de_sede "Forbidden" 403
	#
	# @catalogo_fuera_de_sede {
	# 	method GET
	# 	path /kioscos
	# 	not remote_ip {$SEDE_IPS}
	# }
	# respond @catalogo_fuera_de_sede "Forbidden" 403
}
