# Plantilla de entorno para la suite E2E VISIBLE (frontend/e2e).
# Copia a `.env.e2e` (gitignored) y rellena. NUNCA commitear credenciales reales.
# Carga: exporta estas variables antes de `npm run e2e*` (o usa dotenv-cli / tu shell).

# ── URLs del entorno bajo prueba ──────────────────────────────────────────────
E2E_BASE_URL=http://localhost:5173
E2E_API_URL=http://localhost:3000

# ── Modo y BARRERA DE ESCRITURA ───────────────────────────────────────────────
# dev | staging | production. En production TODO @full se auto-skipea (solo lectura).
E2E_MODE=dev
# La escritura (@full) exige AMBAS: E2E_MODE!=production Y E2E_ALLOW_WRITES=true.
# Por defecto false → fail-safe: no escribe nada.
E2E_ALLOW_WRITES=false

# ── Credenciales (SOLO en .env.e2e local, jamás en el repo) ───────────────────
# Admin de TENANT para el smoke read-only y los @full de negocio/usuarios.
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
# Super-admin de PLATAFORMA (para los specs de plataforma, Phase 2).
E2E_SUPERADMIN_EMAIL=
E2E_SUPERADMIN_PASSWORD=
