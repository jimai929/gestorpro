{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/hooks/deploy-guard.js\"",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git diff --check*)",
      "Bash(git log*)",
      "Bash(git branch --show-current)",
      "Bash(git rev-parse*)",
      "PowerShell(git status*)",
      "PowerShell(git diff*)",
      "PowerShell(git diff --check*)",
      "PowerShell(git log*)",
      "PowerShell(git branch --show-current)",
      "PowerShell(git rev-parse*)",
      "Bash(npm test*)",
      "Bash(npm run test*)",
      "Bash(npm run typecheck*)",
      "Bash(npm run build*)",
      "PowerShell(npm test*)",
      "PowerShell(npm run test*)",
      "PowerShell(npm run typecheck*)",
      "PowerShell(npm run build*)"
    ],
    "ask": [
      "Bash(git push*)",
      "PowerShell(git push*)",
      "Bash(*deploy.sh*)",
      "PowerShell(*deploy.sh*)",
      "Bash(docker compose up*)",
      "Bash(docker compose restart*)",
      "PowerShell(docker compose up*)",
      "PowerShell(docker compose restart*)",
      "Bash(ssh*)",
      "PowerShell(ssh*)",
      "Bash(*prisma migrate deploy*)",
      "PowerShell(*prisma migrate deploy*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "PowerShell(git push --force*)",
      "PowerShell(git push -f*)",
      "Bash(git reset --hard*)",
      "PowerShell(git reset --hard*)",
      "Bash(git clean -f*)",
      "PowerShell(git clean -f*)",
      "Bash(docker compose down*)",
      "PowerShell(docker compose down*)",
      "Bash(*prisma migrate reset*)",
      "PowerShell(*prisma migrate reset*)",
      "Bash(*prisma db push*)",
      "PowerShell(*prisma db push*)",
      "Bash(*prisma db seed*)",
      "PowerShell(*prisma db seed*)",
      "Bash(npm run db:reset*)",
      "PowerShell(npm run db:reset*)",
      "Read(./.env*)",
      "Read(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.ppk)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/*credentials*.json)"
    ]
  }
}
