// Esquema único de toda la app GestorPro (finanzas + asistencia).
//
// Núcleo de datos (Tarea 0.2): las entidades transversales que usan ambas
// áreas. Las entidades de finanzas (Fases 1-3) y de asistencia (Fases 4-6) se
// añaden aquí mismo en sus fases. La URL de conexión vive en prisma.config.ts.
//
// Convención: tablas y columnas en snake_case (vía @@map/@map). Así el SQL
// manual del proyecto (vistas, índices parciales, REVOKE) queda legible sin
// comillas. El cliente Prisma se genera en src/generated/prisma.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Rol de un usuario del sistema. Determina la autorización en cada ruta.
enum Rol {
  empleado
  supervisor
  administrador
}

/// Mecanismo permitido para el fichaje de excepción en una sede. Lo consume la
/// asistencia (Fase 4); se declara desde el núcleo porque vive en `Sede`.
enum ModoExcepcion {
  pin
  supervisor
  ambos
}

/// Sede física de la empresa (un cliente puede tener varias).
model Sede {
  id            String        @id @default(uuid()) @db.Uuid
  nombre        String
  activo        Boolean       @default(true)
  modoExcepcion ModoExcepcion @default(pin) @map("modo_excepcion")
  creadoEn      DateTime      @default(now()) @map("creado_en")

  compras   Compra[]
  gastos    Gasto[]
  ventas    VentaDiaria[]
  empleados Empleado[]
  kioscos   Kiosco[]
  turnos    Turno[]
  cajas     Caja[]

  @@map("sede")
}

/// Caja registradora de una sede (punto de cobro). Catálogo GESTIONABLE por el
/// admin desde Administración. El cierre elige una; su `numero` queda como
/// snapshot en `VentaDiaria.caja` (NO es FK: el cierre es auditoría inmutable).
/// El número se RECICLA: solo puede haber UNA caja `activa` por (sede, numero),
/// garantizado por el índice único PARCIAL `uq_caja_sede_numero_activa` (SQL
/// manual en la migración — Prisma no soporta unique parcial declarativo; igual
/// que `uq_venta_normal`). Las inactivas no cuentan, así que un número liberado
/// por una baja se puede reusar. La baja es lógica (`activo`).
model Caja {
  id       String   @id @default(uuid()) @db.Uuid
  sedeId   String   @map("sede_id") @db.Uuid
  sede     Sede     @relation(fields: [sedeId], references: [id])
  numero   String   @db.VarChar(20)
  nombre   String
  activo   Boolean  @default(true)
  creadoEn DateTime @default(now()) @map("creado_en")

  @@index([sedeId])
  @@map("caja")
}

/// Cuenta de acceso al sistema. La crea un administrador (no hay registro
/// abierto). La contraseña SIEMPRE se guarda hasheada en `passwordHash`,
/// nunca en texto plano.
model Usuario {
  id           String   @id @default(uuid()) @db.Uuid
  nombre       String
  email        String   @unique
  rol          Rol      @default(empleado)
  passwordHash String   @map("password_hash")
  activo       Boolean  @default(true)
  creadoEn     DateTime @default(now()) @map("creado_en")

  sesiones SesionRefresco[]

  @@map("usuario")
}

/// Sesión de refresco: un refresh token vivo por inicio de sesión. El token se
/// guarda HASHEADO (SHA-256), nunca en claro. El logout borra la fila, con lo
/// que el refresh token queda invalidado del lado del servidor.
model SesionRefresco {
  id        String   @id @default(uuid()) @db.Uuid
  usuarioId String   @map("usuario_id") @db.Uuid
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  tokenHash String   @unique @map("token_hash")
  expiraEn  DateTime @map("expira_en")
  creadoEn  DateTime @default(now()) @map("creado_en")

  @@index([usuarioId])
  @@map("sesion_refresco")
}

/// Bitácora append-only: SOLO inserción, nunca update ni delete. Se escribe
/// únicamente a través del repositorio de auditoría (Fase 1) y se refuerza con
/// un REVOKE en Postgres. No tiene relaciones para mantener su superficie
/// cerrada y desacoplada.
model Auditoria {
  id        String   @id @default(uuid()) @db.Uuid
  entidad   String
  entidadId String   @map("entidad_id")
  accion    String
  usuarioId String   @map("usuario_id") @db.Uuid
  detalle   Json?
  creadoEn  DateTime @default(now()) @map("creado_en")

  @@map("auditoria")
}

// ─── Finanzas · Cuentas por pagar (Fase 1) ──────────────────────────────────

/// Tipo de asiento de un movimiento de dinero. Los movimientos son INMUTABLES:
/// una corrección se hace con un `reverso` (anula el asiento previo) y, si
/// aplica, una `correccion` con el monto correcto, encadenados por `corrigeId`.
enum TipoMovimiento {
  normal
  reverso
  correccion
}

/// Forma de pago de una factura de compra. Una compra de `contado` se paga en
/// el acto y NO genera cuenta por pagar: la vista `cuenta_por_pagar` la excluye.
/// Una de `credito` queda como deuda con saldo y vencimiento.
enum TipoCompra {
  contado
  credito
}

/// Proveedor al que se le compra mercancía o servicios.
model Proveedor {
  id                   String   @id @default(uuid()) @db.Uuid
  nombre               String
  identificacionFiscal String?  @map("identificacion_fiscal")
  telefono             String?
  personaContacto      String?  @map("persona_contacto")
  activo               Boolean  @default(true)
  creadoEn             DateTime @default(now()) @map("creado_en")

  compras Compra[]

  @@map("proveedor")
}

/// Factura de compra (obligación de pago). El saldo NO se persiste aquí: se
/// deriva en la vista `cuenta_por_pagar` a partir de los pagos. Criterio
/// devengado: la fecha que cuenta es la de emisión.
model Compra {
  id               String     @id @default(uuid()) @db.Uuid
  proveedorId      String     @map("proveedor_id") @db.Uuid
  proveedor        Proveedor  @relation(fields: [proveedorId], references: [id])
  sedeId           String     @map("sede_id") @db.Uuid
  sede             Sede       @relation(fields: [sedeId], references: [id])
  numeroFactura    String     @map("numero_factura")
  montoTotal       Decimal    @map("monto_total") @db.Decimal(12, 2)
  tipo             TipoCompra @default(credito)
  fechaEmision     DateTime   @map("fecha_emision") @db.Date
  fechaVencimiento DateTime?  @map("fecha_vencimiento") @db.Date
  creadoEn         DateTime   @default(now()) @map("creado_en")

  pagos PagoProveedor[]

  @@unique([proveedorId, numeroFactura], map: "uq_compra_factura")
  @@index([sedeId])
  @@map("compra")
}

/// Pago (abono) a una factura. MOVIMIENTO DE DINERO INMUTABLE: no se edita ni
/// se borra; se corrige con reverso + corrección (ver TipoMovimiento). El
/// `usuarioId` proviene del token JWT, nunca del body.
model PagoProveedor {
  id           String          @id @default(uuid()) @db.Uuid
  compraId     String          @map("compra_id") @db.Uuid
  compra       Compra          @relation(fields: [compraId], references: [id])
  monto        Decimal         @db.Decimal(12, 2)
  fechaPago    DateTime        @map("fecha_pago") @db.Date
  tipo         TipoMovimiento  @default(normal)
  corrigeId    String?         @map("corrige_id") @db.Uuid
  corrige      PagoProveedor?  @relation("CorreccionPago", fields: [corrigeId], references: [id])
  correcciones PagoProveedor[] @relation("CorreccionPago")
  motivo       String?
  usuarioId    String          @map("usuario_id") @db.Uuid
  creadoEn     DateTime        @default(now()) @map("creado_en")

  @@index([compraId])
  @@map("pago_proveedor")
}

// ─── Finanzas · Gastos (Fase 2) ─────────────────────────────────────────────

/// Categoría de gasto. Tabla GESTIONABLE por el admin (no un enum). El flag
/// `esPagoEmpleado` marca las categorías de pago a empleados, que exigen datos
/// de empleado en el gasto (regla de coherencia).
model CategoriaGasto {
  id             String   @id @default(uuid()) @db.Uuid
  nombre         String   @unique
  esPagoEmpleado Boolean  @default(false) @map("es_pago_empleado")
  activo         Boolean  @default(true)
  creadoEn       DateTime @default(now()) @map("creado_en")

  gastos Gasto[]

  @@map("categoria_gasto")
}

/// Gasto operativo (no mercancía). MOVIMIENTO DE DINERO INMUTABLE: se corrige
/// con reverso + corrección (TipoMovimiento). Coherencia de empleado: si la
/// categoría es de pago a empleado exige `empleadoId`; si no, `empleadoId` y
/// `tipoPago` deben ir vacíos. `referenciaOrigen` es el gancho del cobro de
/// horas extra (Fase 6): un gasto con ese campo lleno ya está contabilizado
/// (evita el doble pago). El FK de `empleadoId` se añadirá con Empleado (Fase 4).
model Gasto {
  id               String         @id @default(uuid()) @db.Uuid
  categoriaId      String         @map("categoria_id") @db.Uuid
  categoria        CategoriaGasto @relation(fields: [categoriaId], references: [id])
  sedeId           String         @map("sede_id") @db.Uuid
  sede             Sede           @relation(fields: [sedeId], references: [id])
  monto            Decimal        @db.Decimal(12, 2)
  fechaOperacion   DateTime       @map("fecha_operacion") @db.Date
  descripcion      String?
  empleadoId       String?        @map("empleado_id") @db.Uuid
  tipoPago         String?        @map("tipo_pago")
  referenciaOrigen String?        @map("referencia_origen")
  tipo             TipoMovimiento @default(normal)
  corrigeId        String?        @map("corrige_id") @db.Uuid
  corrige          Gasto?         @relation("CorreccionGasto", fields: [corrigeId], references: [id])
  correcciones     Gasto[]        @relation("CorreccionGasto")
  motivo           String?
  usuarioId        String         @map("usuario_id") @db.Uuid
  creadoEn         DateTime       @default(now()) @map("creado_en")

  @@index([categoriaId])
  @@index([sedeId])
  @@index([fechaOperacion])
  @@map("gasto")
}

// ─── Finanzas · Cierre de caja con arqueo (Fase 3) ──────────────────────────

/// Turno del cierre de caja (operación de 24 h en tres turnos). Es una capa
/// PROPIA de finanzas; NO se relaciona con el `Turno` de asistencia (otra área).
enum TurnoVenta {
  manana
  tarde
  noche
}

/// Tipo de componente del arqueo de caja: lo que hay en el cajón al cerrar. La
/// lotería son premios pagados que están en el cajón, NO un ingreso. El arqueo
/// existe para cuadrar la caja contra Firestec, no para analizar ventas por tipo.
enum TipoArqueo {
  efectivo
  tarjeta
  yappy
  loteria
}

/// Cierre de caja de un turno (dato tecleado desde Firestec). MOVIMIENTO DE
/// DINERO INMUTABLE: se corrige con reverso + corrección. Solo puede existir UN
/// cierre `normal` por (sede, fecha, turno, caja): lo garantiza el índice único
/// parcial `uq_venta_normal` (en SQL manual), que exenta los asientos de
/// corrección. El `monto` es el TOTAL del arqueo (= suma de `detalles`) y debe
/// cuadrar con el total que reporta Firestec. `cerradoPor` es solo la
/// identificación de quién hizo el cierre (NO es FK a Empleado: las horas
/// trabajadas son de asistencia). `horaApertura`/`horaCierre` son descriptivas.
model VentaDiaria {
  id             String          @id @default(uuid()) @db.Uuid
  sedeId         String          @map("sede_id") @db.Uuid
  sede           Sede            @relation(fields: [sedeId], references: [id])
  fechaOperacion DateTime        @map("fecha_operacion") @db.Date
  turno          TurnoVenta
  caja           String          @db.VarChar(20)
  cerradoPor     String          @map("cerrado_por")
  horaApertura   String?         @map("hora_apertura")
  horaCierre     String?         @map("hora_cierre")
  monto          Decimal         @db.Decimal(12, 2)
  detalles       DetalleCierre[]
  tipo           TipoMovimiento  @default(normal)
  corrigeId      String?         @map("corrige_id") @db.Uuid
  corrige        VentaDiaria?    @relation("CorreccionVenta", fields: [corrigeId], references: [id])
  correcciones   VentaDiaria[]   @relation("CorreccionVenta")
  motivo         String?
  usuarioId      String          @map("usuario_id") @db.Uuid
  creadoEn       DateTime        @default(now()) @map("creado_en")

  @@index([sedeId])
  @@index([fechaOperacion])
  @@map("venta_diaria")
}

/// Línea del arqueo de caja: el monto contado de un tipo (efectivo, tarjeta,
/// Yappy, lotería) dentro de un cierre. Inmutable como su cierre. La suma de las
/// líneas es el total del cierre; sirve para cuadrar la caja contra Firestec y
/// detectar descuadres, no para calcular ganancia por tipo.
model DetalleCierre {
  id         String      @id @default(uuid()) @db.Uuid
  ventaId    String      @map("venta_id") @db.Uuid
  venta      VentaDiaria @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  tipoArqueo TipoArqueo  @map("tipo_arqueo")
  monto      Decimal     @db.Decimal(12, 2)

  @@unique([ventaId, tipoArqueo])
  @@index([ventaId])
  @@map("detalle_cierre")
}

// ─── Asistencia · Fichaje y kioscos (Fase 4) ────────────────────────────────

/// Los cuatro momentos de fichaje del día.
enum TipoFichaje {
  entrada
  salida_comida
  entrada_comida
  salida
}

/// Mecanismo con que se permitió un fichaje de excepción (cuando el facial falla).
enum MecanismoExcepcion {
  pin
  supervisor
}

/// Empleado que ficha. Salario fijo. El `pinHash` es el PIN personal HASHEADO
/// (nunca texto plano); el `qrToken` es único y revocable (se regenera). La
/// `fotoReferencia` es el dato contra el que compara la verificación facial.
model Empleado {
  id             String   @id @default(uuid()) @db.Uuid
  numero         String   @unique
  nombre         String
  sedeId         String   @map("sede_id") @db.Uuid
  sede           Sede     @relation(fields: [sedeId], references: [id])
  qrToken        String   @unique @map("qr_token")
  pinHash        String   @map("pin_hash")
  fotoReferencia String?  @map("foto_referencia")
  salarioFijo    Decimal  @map("salario_fijo") @db.Decimal(12, 2)
  turnoId        String?  @map("turno_id") @db.Uuid
  turno          Turno?   @relation(fields: [turnoId], references: [id])
  activo         Boolean  @default(true)
  creadoEn       DateTime @default(now()) @map("creado_en")

  fichajes        Fichaje[]
  jornadas        Jornada[]
  saldoHorasExtra SaldoHorasExtra?
  solicitudes     SolicitudCobro[]

  @@map("empleado")
}

/// Kiosco (tablet/PC) de fichaje, pertenece a una sede.
model Kiosco {
  id       String   @id @default(uuid()) @db.Uuid
  nombre   String
  sedeId   String   @map("sede_id") @db.Uuid
  sede     Sede     @relation(fields: [sedeId], references: [id])
  activo   Boolean  @default(true)
  creadoEn DateTime @default(now()) @map("creado_en")

  fichajes Fichaje[]

  @@map("kiosco")
}

/// Fichaje: hecho crudo INMUTABLE (no se edita ni borra). Si fue de excepción
/// (facial falló pero el empleado se identificó), queda marcado para revisión
/// del jefe. La validez la decide el jefe en `RevisionFichaje`, sin mutar esto.
model Fichaje {
  id                 String              @id @default(uuid()) @db.Uuid
  empleadoId         String              @map("empleado_id") @db.Uuid
  empleado           Empleado            @relation(fields: [empleadoId], references: [id])
  kioscoId           String              @map("kiosco_id") @db.Uuid
  kiosco             Kiosco              @relation(fields: [kioscoId], references: [id])
  tipo               TipoFichaje
  momento            DateTime            @default(now())
  esExcepcion        Boolean             @default(false) @map("es_excepcion")
  mecanismoExcepcion MecanismoExcepcion? @map("mecanismo_excepcion")
  requiereRevision   Boolean             @default(false) @map("requiere_revision")
  fotoCaptura        String?             @map("foto_captura")
  creadoEn           DateTime            @default(now()) @map("creado_en")

  revision RevisionFichaje?

  @@index([empleadoId])
  @@index([kioscoId])
  @@index([momento])
  @@map("fichaje")
}

/// Revisión del jefe sobre un fichaje de excepción. Una por fichaje; no muta el
/// Fichaje (que es inmutable): aquí se decide su validez.
model RevisionFichaje {
  id        String   @id @default(uuid()) @db.Uuid
  fichajeId String   @unique @map("fichaje_id") @db.Uuid
  fichaje   Fichaje  @relation(fields: [fichajeId], references: [id])
  jefeId    String   @map("jefe_id") @db.Uuid
  valido    Boolean
  motivo    String?
  creadoEn  DateTime @default(now()) @map("creado_en")

  @@map("revision_fichaje")
}

// ─── Asistencia · Motor de jornada (Fase 5) ─────────────────────────────────

/// Turno: capa CONFIGURABLE de la jornada (horario, tolerancia de tardanza,
/// pausa de respaldo, día de descanso semanal). Lo gestiona el admin. La capa
/// legal (jornadas, recargos, topes) es FIJA y vive en el motor, no aquí.
model Turno {
  id                 String   @id @default(uuid()) @db.Uuid
  nombre             String
  sedeId             String?  @map("sede_id") @db.Uuid
  sede               Sede?    @relation(fields: [sedeId], references: [id])
  horaInicio         String   @map("hora_inicio")
  horaFin            String   @map("hora_fin")
  toleranciaMin      Int      @default(0) @map("tolerancia_min")
  pausaPorDefectoMin Int      @default(0) @map("pausa_por_defecto_min")
  diaDescanso        Int?     @map("dia_descanso")
  activo             Boolean  @default(true)
  creadoEn           DateTime @default(now()) @map("creado_en")

  empleados Empleado[]

  @@map("turno")
}

/// Jornada: interpretación CALCULADA de los fichajes de un empleado en un día.
/// Recalculable y sobreescribible (NO append-only); una por (empleado, fecha).
/// La fecha es la de INICIO del turno (ata los turnos que cruzan medianoche).
model Jornada {
  id                String   @id @default(uuid()) @db.Uuid
  empleadoId        String   @map("empleado_id") @db.Uuid
  empleado          Empleado @relation(fields: [empleadoId], references: [id])
  fecha             DateTime @db.Date
  minutosPresencia  Int      @default(0) @map("minutos_presencia")
  minutosPausa      Int      @default(0) @map("minutos_pausa")
  minutosTrabajados Int      @default(0) @map("minutos_trabajados")
  minutosOrdinarios Int      @default(0) @map("minutos_ordinarios")
  minutosExtra      Int      @default(0) @map("minutos_extra")
  clasificacion     String?
  recargosDetalle   Json?    @map("recargos_detalle")
  montoExtra        Decimal  @default(0) @map("monto_extra") @db.Decimal(12, 2)
  esFestivo         Boolean  @default(false) @map("es_festivo")
  anomalia          Boolean  @default(false)
  detalleAnomalia   String?  @map("detalle_anomalia")
  estado            String   @default("calculada")
  calculadaEn       DateTime @default(now()) @map("calculada_en")

  correcciones Correccion[]

  @@unique([empleadoId, fecha], map: "uq_jornada_empleado_fecha")
  @@map("jornada")
}

/// Corrección: registro INMUTABLE y auditado de cada ajuste humano a una
/// jornada. La jornada se recalcula; estas correcciones son la huella de quién
/// ajustó qué y por qué.
model Correccion {
  id            String   @id @default(uuid()) @db.Uuid
  jornadaId     String   @map("jornada_id") @db.Uuid
  jornada       Jornada  @relation(fields: [jornadaId], references: [id])
  usuarioId     String   @map("usuario_id") @db.Uuid
  valorAnterior Json?    @map("valor_anterior")
  valorNuevo    Json?    @map("valor_nuevo")
  motivo        String
  creadoEn      DateTime @default(now()) @map("creado_en")

  @@index([jornadaId])
  @@map("correccion")
}

/// Día festivo, gestionable por el admin. Dos efectos en el motor: dispara el
/// recargo de 150% si se trabaja, y protege el día contra descuento si no se
/// trabaja (salario fijo).
model DiaFestivo {
  id       String   @id @default(uuid()) @db.Uuid
  fecha    DateTime @unique @db.Date
  nombre   String
  creadoEn DateTime @default(now()) @map("creado_en")

  @@map("dia_festivo")
}

// ─── Asistencia · Cobro anticipado de horas extra (Fase 6) ──────────────────

/// Estado de una solicitud de cobro (Modelo B): bajo el umbral nace 'aprobada'
/// (cobro directo); sobre el umbral nace 'pendiente' (espera al jefe).
enum EstadoSolicitudCobro {
  pendiente
  aprobada
  rechazada
  pagada
}

/// Saldo de horas extra por empleado. PERSISTIDO y en DINERO (no en horas). Lo
/// escribe SOLO el servicio transaccional de saldo (Fase 6.2); nunca negativo
/// (reforzado con un CHECK en Postgres). El motor de jornada acredita el monto
/// ya con recargo aplicado.
model SaldoHorasExtra {
  id            String   @id @default(uuid()) @db.Uuid
  empleadoId    String   @unique @map("empleado_id") @db.Uuid
  empleado      Empleado @relation(fields: [empleadoId], references: [id])
  saldo         Decimal  @default(0) @db.Decimal(12, 2)
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  @@map("saldo_horas_extra")
}

/// Solicitud de cobro anticipado contra el saldo. La app no mueve dinero real:
/// el admin entrega el efectivo por fuera y marca 'pagada', lo que genera el
/// Gasto en finanzas con referenciaOrigen (Fase 6.4). El `monto` ya tiene el %
/// cobrable aplicado (fracción adelantable del dinero ganado).
model SolicitudCobro {
  id            String               @id @default(uuid()) @db.Uuid
  empleadoId    String               @map("empleado_id") @db.Uuid
  empleado      Empleado             @relation(fields: [empleadoId], references: [id])
  monto         Decimal              @db.Decimal(12, 2)
  estado        EstadoSolicitudCobro @default(pendiente)
  aprobadoPorId String?              @map("aprobado_por_id") @db.Uuid
  motivoRechazo String?              @map("motivo_rechazo")
  resueltoEn    DateTime?            @map("resuelto_en")
  pagadoEn      DateTime?            @map("pagado_en")
  creadoEn      DateTime             @default(now()) @map("creado_en")

  @@index([empleadoId])
  @@index([estado])
  @@map("solicitud_cobro")
}

/// Configuración ÚNICA del cobro (gestionada por el admin): porcentaje cobrable
/// (0–100, aplicado sobre el monto en dinero) y umbral del Modelo B (bajo él, el
/// cobro es directo). Fila única gestionada por la app.
model ConfiguracionCobro {
  id                 String   @id @default(uuid()) @db.Uuid
  porcentajeCobrable Int      @default(80) @map("porcentaje_cobrable")
