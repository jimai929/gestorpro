// Esquema Ãšnico de toda la app GestorPro (finanzas + asistencia).
//
// NÃšcleo de datos (Tarea 0.2): las entidades transversales que usan ambas
// ÃĄreas. Las entidades de finanzas (Fases 1-3) y de asistencia (Fases 4-6) se
// aÃąaden aquÃ­ mismo en sus fases. La URL de conexiÃģn vive en prisma.config.ts.
//
// ConvenciÃģn: tablas y columnas en snake_case (vÃ­a @@map/@map). AsÃ­ el SQL
// manual del proyecto (vistas, Ã­ndices parciales, REVOKE) queda legible sin
// comillas. El cliente Prisma se genera en src/generated/prisma.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Rol de un usuario del sistema. Determina la autorizaciÃģn en cada ruta.
enum Rol {
  empleado
  supervisor
  administrador
}

/// Mecanismo permitido para el fichaje de excepciÃģn en una sede. Lo consume la
/// asistencia (Fase 4); se declara desde el nÃšcleo porque vive en `Sede`.
enum ModoExcepcion {
  pin
  supervisor
  ambos
}

/// Sede fÃ­sica de la empresa (un cliente puede tener varias).
/// Tenant raÃ­z del SaaS multi-empresa. Cada fila es un cliente aislado. El
/// aislamiento entre empresas es fail-closed (RLS bajo gestorpro_app); ver
/// docs/ARQUITECTURA_MULTITENANT.md.
model Empresa {
  id          String   @id @default(uuid()) @db.Uuid
  nombre      String
  slug        String   @unique
  activo      Boolean  @default(true)
  plan        String   @default("base")
  zonaHoraria String   @default("America/Panama") @map("zona_horaria")
  creadoEn    DateTime @default(now()) @map("creado_en")

  membresias           Membresia[]
  sedes                Sede[]
  empleados            Empleado[]
  proveedores          Proveedor[]
  categoriasGasto      CategoriaGasto[]
  rolesOperativos      RolOperativo[]
  turnos               Turno[]
  diasFestivos         DiaFestivo[]
  configuracionesCobro ConfiguracionCobro[]
  auditorias           Auditoria[]
  auditoriasPlataforma AuditoriaPlataforma[]

  @@map("empresa")
}

/// Pertenencia de un Usuario a una Empresa con un rol concreto (N:M). Un usuario
/// puede tener varias; `predeterminada` marca la activa por defecto en login. El
/// super-admin de plataforma es un Usuario SIN ninguna Membresia.
model Membresia {
  id             String   @id @default(uuid()) @db.Uuid
  usuarioId      String   @map("usuario_id") @db.Uuid
  usuario        Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  empresaId      String   @map("empresa_id") @db.Uuid
  empresa        Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  rol            Rol      @default(empleado)
  predeterminada Boolean  @default(false)
  creadoEn       DateTime @default(now()) @map("creado_en")

  @@unique([usuarioId, empresaId])
  @@index([empresaId])
  @@map("membresia")
}

model Sede {
  id            String        @id @default(uuid()) @db.Uuid
  empresaId     String        @default(dbgenerated("NULLIF(current_setting('app.empresa_id', true), '')::uuid")) @map("empresa_id") @db.Uuid
  nombre        String
  activo        Boolean       @default(true)
  modoExcepcion ModoExcepcion @default(pin) @map("modo_excepcion")
  creadoEn      DateTime      @default(now()) @map("creado_en")

  compras   Compra[]
  gastos    Gasto[]
  ventas    VentaDiaria[]
  empleados Empleado[]
  kioscos   Kiosco[]
  turnos    Turno[]
  empresa Empresa? @relation(fields: [empresaId], references: [id], onDelete: Restrict)

  // Destino de la FK compuesta de empleado(sede_id, empresa_id) (Fase 3 Ola 3c).
  // sede.id ya es PK; este unique compuesto solo habilita la FK compuesta.
  @@unique([id, empresaId])
  @@map("sede")
}

/// Cuenta de acceso al sistema. La crea un administrador (no hay registro
/// abierto). La contraseÃąa SIEMPRE se guarda hasheada en `passwordHash`,
/// nunca en texto plano.
model Usuario {
  id           String   @id @default(uuid()) @db.Uuid
  nombre       String
  email        String   @unique
  rol          Rol      @default(empleado)
  passwordHash String   @map("password_hash")
  activo       Boolean  @default(true)
  esSuperAdmin Boolean  @default(false) @map("es_super_admin")
  // Cuenta creada por un tercero con contraseÃąa temporal (POST /empresas, POST /usuarios):
  // debe rotarla en el primer login. Se limpia (false) al cambiar la contraseÃąa.
  debeCambiarContrasena Boolean @default(false) @map("debe_cambiar_contrasena")
  creadoEn     DateTime @default(now()) @map("creado_en")

  sesiones   SesionRefresco[]
  membresias Membresia[]

  @@map("usuario")
}

/// SesiÃģn de refresco: un refresh token vivo por inicio de sesiÃģn. El token se
/// guarda HASHEADO (SHA-256), nunca en claro. El logout borra la fila, con lo
/// que el refresh token queda invalidado del lado del servidor.
model SesionRefresco {
  id        String   @id @default(uuid()) @db.Uuid
  usuarioId String   @map("usuario_id") @db.Uuid
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  empresaIdActiva String? @map("empresa_id_activa") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiraEn  DateTime @map("expira_en")
  creadoEn  DateTime @default(now()) @map("creado_en")

  @@index([usuarioId])
  @@map("sesion_refresco")
}

/// BitÃĄcora append-only: SOLO inserciÃģn, nunca update ni delete. Se escribe
/// Ãšnicamente a travÃĐs del repositorio de auditorÃ­a (Fase 1) y se refuerza con
/// un REVOKE en Postgres. No tiene relaciones para mantener su superficie
/// cerrada y desacoplada.
model Auditoria {
  id        String   @id @default(uuid()) @db.Uuid
  empresaId String @default(dbgenerated("NULLIF(current_setting('app.empresa_id', true), '')::uuid")) @map("empresa_id") @db.Uuid
  entidad   String
  entidadId String   @map("entidad_id")
  accion    String
  usuarioId String   @map("usuario_id") @db.Uuid
  detalle   Json?
  creadoEn  DateTime @default(now()) @map("creado_en")
  empresa Empresa? @relation(fields: [empresaId], references: [id], onDelete: Restrict)

  @@map("auditoria")
}

/// BitÃĄcora APPEND-ONLY de operaciones de PLATAFORMA (super-admin), SEPARADA de la
/// auditorÃ­a de tenant (`Auditoria`). NO lleva RLS ni empresa_id de particiÃģn: es un
/// registro a nivel plataforma (allowlist en post-migrate.sql, como usuario/empresa).
/// `empresaAfectadaId` (opcional) referencia la empresa OBJETO de la acciÃģn; es NULL en
/// acciones de plataforma sin empresa. NUNCA guarda contraseÃąas ni secretos en `detalle`.
/// Inmutable: el REVOKE de UPDATE/DELETE (post-migrate.sql) + la ausencia de mÃĐtodos de
/// escritura fuera de `registrar` la protegen, igual que `Auditoria`.
model AuditoriaPlataforma {
  id                String   @id @default(uuid()) @db.Uuid
  /// Super-admin que ejecutÃģ la acciÃģn (SIEMPRE del token, nunca del body).
  actorUsuarioId    String   @map("actor_usuario_id") @db.Uuid
  /// Empresa objeto de la acciÃģn; NULL en acciones de plataforma sin empresa.
  empresaAfectadaId String?  @map("empresa_afectada_id") @db.Uuid
  accion            String
  detalle           Json?
  /// IP del actor, si el contexto la provee (hoy NULL: el servicio aÃšn no la recibe).
  ip                String?
  creadoEn          DateTime @default(now()) @map("creado_en")

  empresaAfectada Empresa? @relation(fields: [empresaAfectadaId], references: [id], onDelete: Restrict)

  @@index([empresaAfectadaId])
  @@index([actorUsuarioId])
  @@map("auditoria_plataforma")
}

// âââ Finanzas Â· Cuentas por pagar (Fase 1) ââââââââââââââââââââââââââââââââââ

/// Tipo de asiento de un movimiento de dinero. Los movimientos son INMUTABLES:
/// una correcciÃģn se hace con un `reverso` (anula el asiento previo) y, si
/// aplica, una `correccion` con el monto correcto, encadenados por `corrigeId`.
enum TipoMovimiento {
  normal
  reverso
  correccion
}

/// Forma de pago de una factura de compra. Una compra de `contado` se paga en
/// el acto y NO genera cuenta por pagar: la vista `cuenta_por_pagar` la excluye.
/// Una de `credito` queda como deuda con saldo y vencimiento.
enum TipoCompra {
  contado
  credito
}

/// Proveedor al que se le compra mercancÃ­a o servicios.
model Proveedor {
  id                   String   @id @default(uuid()) @db.Uuid
  empresaId            String @default(dbgenerated("NULLIF(current_setting('app.empresa_id', true), '')::uuid")) @map("empresa_id") @db.Uuid
  nombre               String
  identificacionFiscal String?  @map("identificacion_fiscal")
  telefono             String?
  personaContacto      String?  @map("persona_contacto")
  activo               Boolean  @default(true)
  creadoEn             DateTime @default(now()) @map("creado_en")

  compras Compra[]
  empresa Empresa? @relation(fields: [empresaId], references: [id], onDelete: Restrict)

  @@map("proveedor")
}

/// Factura de compra (obligaciÃģn de pago). El saldo NO se persiste aquÃ­: se
/// deriva en la vista `cuenta_por_pagar` a partir de los pagos. Criterio
/// devengado: la fecha que cuenta es la de emisiÃģn.
model Compra {
  id               String     @id @default(uuid()) @db.Uuid
  proveedorId      String     @map("proveedor_id") @db.Uuid
  proveedor        Proveedor  @relation(fields: [proveedorId], references: [id])
  sedeId           String     @map("sede_id") @db.Uuid
  sede             Sede       @relation(fields: [sedeId], references: [id])
  numeroFactura    String     @map("numero_factura")
  montoTotal       Decimal    @map("monto_total") @db.Decimal(12, 2)
  tipo             TipoCompra @default(credito)
  fechaEmision     DateTime   @map("fecha_emision") @db.Date
  fechaVencimiento DateTime?  @map("fecha_vencimiento") @db.Date
  creadoEn         DateTime   @default(now()) @map("creado_en")

  pagos PagoProveedor[]

  @@unique([proveedorId, numeroFactura], map: "uq_compra_factura")
  @@index([sedeId])
  @@map("compra")
}

/// Pago (abono) a una factura. MOVIMIENTO DE DINERO INMUTABLE: no se edita ni
/// se borra; se corrige con reverso + correcciÃģn (ver TipoMovimiento). El
/// `usuarioId` proviene del token JWT, nunca del body.
model PagoProveedor {
  id           String          @id @default(uuid()) @db.Uuid
  compraId     String          @map("compra_id") @db.Uuid
  compra       Compra          @relation(fields: [compraId], references: [id])
  monto        Decimal         @db.Decimal(12, 2)
  fechaPago    DateTime        @map("fecha_pago") @db.Date
  tipo         TipoMovimiento  @default(normal)
  corrigeId    String?         @map("corrige_id") @db.Uuid
  corrige      PagoProveedor?  @relation("CorreccionPago", fields: [corrigeId], references: [id])
  correcciones PagoProveedor[] @relation("CorreccionPago")
  motivo       String?
  usuarioId    String          @map("usuario_id") @db.Uuid
  creadoEn     DateTime        @default(now()) @map("creado_en")

  @@index([compraId])
  @@map("pago_proveedor")
}

// âââ Finanzas Â· Gastos (Fase 2) âââââââââââââââââââââââââââââââââââââââââââââ

/// CategorÃ­a de gasto. Tabla GESTIONABLE por el admin (no un enum). El flag
/// `esPagoEmpleado` marca las categorÃ­as de pago a empleados, que exigen datos
/// de empleado en el gasto (regla de coherencia).
model CategoriaGasto {
  id             String   @id @default(uuid()) @db.Uuid
  empresaId      String @default(dbgenerated("NULLIF(current_setting('app.empresa_id', true), '')::uuid")) @map("empresa_id") @db.Uuid
  nombre         String
  esPagoEmpleado Boolean  @default(false) @map("es_pago_empleado")
  activo         Boolean  @default(true)
  creadoEn       DateTime @default(now()) @map("creado_en")

  gastos Gasto[]
  empresa Empresa? @relation(fields: [empresaId], references: [id], onDelete: Restrict)

  // Fase 3 (slice): nombre UNICO POR EMPRESA (antes @unique global), ahora que
  // categoria_gasto tiene empresa_id. Cada empresa tiene su propio catalogo.
  @@unique([empresaId, nombre])
  @@map("categoria_gasto")
}

/// Gasto operativo (no mercancÃ­a). MOVIMIENTO DE DINERO INMUTABLE: se corrige
/// con reverso + correcciÃģn (TipoMovimiento). Coherencia de empleado: si la
/// categorÃ­a es de pago a empleado exige `empleadoId`; si no, `empleadoId` y
/// `tipoPago` deben ir vacÃ­os. `referenciaOrigen` es el gancho del cobro de
/// horas extra (Fase 6): un gasto con ese campo lleno ya estÃĄ contabilizado
/// (evita el doble pago). El FK de `empleadoId` se aÃąadirÃĄ con Empleado (Fase 4).
model Gasto {
  id               String         @id @default(uuid()) @db.Uuid
  categoriaId      String         @map("categoria_id") @db.Uuid
  categoria        CategoriaGasto @relation(fields: [categoriaId], references: [id])
  sedeId           String         @map("sede_id") @db.Uuid
  sede             Sede           @relation(fields: [sedeId], references: [id])
  monto            Decimal        @db.Decimal(12, 2)
  fechaOperacion   DateTime       @map("fecha_operacion") @db.Date
  descripcion      String?
  empleadoId       String?        @map("empleado_id") @db.Uuid
  tipoPago         String?        @map("tipo_pago")
  referenciaOrigen String?        @map("referencia_origen")
  tipo             TipoMovimiento @default(normal)
  corrigeId        String?        @map("corrige_id") @db.Uuid
  corrige          Gasto?         @relation("CorreccionGasto", fields: [corrigeId], references: [id])
  correcciones     Gasto[]        @relation("CorreccionGasto")
  motivo           String?
  usuarioId        String         @map("usuario_id") @db.Uuid
  creadoEn         DateTime       @default(now()) @map("creado_en")

  @@index([categoriaId])
  @@index([sedeId])
  @@index([fechaOperacion])
  @@map("gasto")
}

// âââ Finanzas Â· Cierre de caja con arqueo (Fase 3) ââââââââââââââââââââââââââ

/// Turno del cierre de caja (operaciÃģn de 24 h en tres turnos). Es una capa
/// PROPIA de finanzas; NO se relaciona con el `Turno` de asistencia (otra ÃĄrea).
enum TurnoVenta {
  manana
  tarde
  noche
}

/// Tipo de componente del arqueo de caja: lo que hay en el cajÃģn al cerrar. La
/// loterÃ­a son premios pagados que estÃĄn en el cajÃģn, NO un ingreso. El arqueo
/// existe para cuadrar la caja contra Firestec, no para analizar ventas por tipo.
enum TipoArqueo {
  efectivo
  tarjeta
  yappy
  loteria
}

/// Cierre de caja de un turno (dato tecleado desde Firestec). MOVIMIENTO DE
/// DINERO INMUTABLE: se corrige con reverso + correcciÃģn. Solo puede existir UN
/// cierre `normal` por (sede, fecha, turno, cajera): lo garantiza el Ã­ndice Ãšnico
/// parcial `uq_venta_normal` (en SQL manual), que exenta los asientos de
/// correcciÃģn. El `monto` es el TOTAL del arqueo (= suma de `detalles`) y debe
/// cuadrar con el total que reporta Firestec. `cajera` (quiÃĐn operÃģ la caja) y
/// `cerradoPor` (quiÃĐn verificÃģ/cerrÃģ) son SNAPSHOT string `"E001 - Nombre"`, NO
/// FK a Empleado: el cierre es auditorÃ­a inmutable y debe quedar legible aunque
/// el empleado cambie. `horaApertura`/`horaCierre` son descriptivas.
model VentaDiaria {
  id             String          @id @default(uuid()) @db.Uuid
  sedeId         String          @map("sede_id") @db.Uuid
  sede           Sede            @relation(fields: [sedeId], references: [id])
  fechaOperacion DateTime        @map("fecha_operacion") @db.Date
  turno          TurnoVenta
  cajera         String          @db.VarChar(120)
  cerradoPor     String          @map("cerrado_por")
  horaApertura   String?         @map("hora_apertura")
  horaCierre     String?         @map("hora_cierre")
  monto          Decimal         @db.Decimal(12, 2)
  detalles       DetalleCierre[]
  tipo           TipoMovimiento  @default(normal)
  corrigeId      String?         @map("corrige_id") @db.Uuid
  corrige        VentaDiaria?    @relation("CorreccionVenta", fields: [corrigeId], references: [id])
  correcciones   VentaDiaria[]   @relation("CorreccionVenta")
  motivo         String?
  usuarioId      String          @map("usuario_id") @db.Uuid
  creadoEn       DateTime        @default(now()) @map("creado_en")

  @@index([sedeId])
  @@index([fechaOperacion])
  @@map("venta_diaria")
}

/// LÃ­nea del arqueo de caja: el monto contado de un tipo (efectivo, tarjeta,
/// Yappy, loterÃ­a) dentro de un cierre. Inmutable como su cierre. La suma de las
/// lÃ­neas es el total del cierre; sirve para cuadrar la caja contra Firestec y
/// detectar descuadres, no para calcular ganancia por tipo.
model DetalleCierre {
  id         String      @id @default(uuid()) @db.Uuid
  ventaId    String      @map("venta_id") @db.Uuid
  venta      VentaDiaria @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  tipoArqueo TipoArqueo  @map("tipo_arqueo")
  monto      Decimal     @db.Decimal(12, 2)

  @@unique([ventaId, tipoArqueo])
  @@index([ventaId])
  @@map("detalle_cierre")
}

// âââ Asistencia Â· Fichaje y kioscos (Fase 4) ââââââââââââââââââââââââââââââââ

/// Los cuatro momentos de fichaje del dÃ­a.
enum TipoFichaje {
  entrada
  salida_comida
  entrada_comida
  salida
}

/// Mecanismo con que se permitiÃģ un fichaje de excepciÃģn (cuando el facial falla).
enum MecanismoExcepcion {
  pin
  supervisor
}

/// Empleado que ficha. Salario fijo. El `pinHash` es el PIN personal HASHEADO
/// (nunca texto plano); el `qrToken` es Ãšnico y revocable (se regenera). La
/// `fotoReferencia` es el dato contra el que compara la verificaciÃģn facial.
model Empleado {
  id             String   @id @default(uuid()) @db.Uuid
  empresaId      String   @default(dbgenerated("NULLIF(current_setting('app.empresa_id', true), '')::uuid")) @map("empresa_id") @db.Uuid
  numero         String
  nombre         String
  sedeId         String   @map("sede_id") @db.Uuid
  // FK COMPUESTA (Fase 3 Ola 3c): (sede_id, empresa_id) -> sede(id, empresa_id). Como
  // sede.id es PK, fuerza empleado.empresa_id = sede.empresa_id a nivel motor (sin CHECK
  // ni trigger). Comparte el escalar empresaId con la relacion a Empresa.
  sede           Sede     @relation(fields: [sedeId, empresaId], references: [id, empresaId], onDelete: Restrict)
  empresa        Empresa  @relation(fields: [empresaId], references: [id], onDelete: Restrict)
  qrToken        String   @map("qr_token")
  pinHash        String   @map("pin_hash")
  fotoReferencia String?  @map("foto_referencia")
  salarioFijo    Decimal  @map("salario_fijo") @db.Decimal(12, 2)
  turnoId        String?  @map("turno_id") @db.Uuid
  turno          Turno?   @relation(fields: [turnoId], references: [id])
  activo         Boolean  @default(true)
  creadoEn       DateTime @default(now()) @map("creado_en")

  fichajes        Fichaje[]
  jornadas        Jornada[]
  saldoHorasExtra SaldoHorasExtra?
  solicitudes     SolicitudCobro[]
  rolesOperativos EmpleadoRolOperativo[]

  // Fase 3: numero/qrToken UNICOS POR EMPRESA (antes @unique global).
  @@unique([empresaId, numero])
  @@unique([empresaId, qrToken])
  @@map("empleado")
}

/// Rol OPERATIVO de un empleado: quÃĐ hace en la operaciÃģn (cajera, verificador y,
/// a futuro, vendedor, tÃĐcnico, supervisorâĶ). Es DISTINTO de `Usuario.rol`, que
/// es la autorizaciÃģn del sistema. CatÃĄlogo EXTENSIBLE (se siembran roles nuevos
/// sin tocar el modelo); la baja es lÃģgica (`activo`). Un empleado puede tener
/// varios a la vez (N:M vÃ­a `EmpleadoRolOperativo`).
model RolOperativo {
  id        String   @id @default(uuid()) @db.Uuid
  empresaId String @default(dbgenerated("NULLIF(current_setting('app.empresa_id', true), '')::uuid")) @map("empresa_id") @db.Uuid
  clave     String   // llave estable de mÃĄquina: 'cajera', 'verificador' (Ãšnica POR empresa)
  nombre   String // etiqueta para mostrar
  activo   Boolean  @default(true)
  creadoEn DateTime @default(now()) @map("creado_en")

  empleados EmpleadoRolOperativo[]
  empresa Empresa? @relation(fields: [empresaId], references: [id], onDelete: Restrict)

  // Fase 5 (slice de Fase 3): clave Ãšnica POR empresa (no global), ahora que
  // rol_operativo tiene empresa_id. Permite que cada empresa tenga su 'cajera'.
  @@unique([empresaId, clave])
  @@map("rol_operativo")
}

/// AsignaciÃģn N:M entre Empleado y RolOperativo (una persona puede ser cajera Y
/// verificador). Join EXPLÃCITO para poder anexar metadatos a futuro. La baja de
/// un empleado o de un rol arrastra sus asignaciones (onDelete: Cascade).
model EmpleadoRolOperativo {
  empleadoId     String       @map("empleado_id") @db.Uuid
  empleado       Empleado     @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  rolOperativoId String       @map("rol_operativo_id") @db.Uuid
  rolOperativo   RolOperativo @relation(fields: [rolOperativoId], references: [id], onDelete: Cascade)
  asignadoEn     DateTime     @default(now()) @map("asignado_en")

  @@id([empleadoId, rolOperativoId])
  @@index([rolOperativoId])
  @@map("empleado_rol_operativo")
}

/// Kiosco (tablet/PC) de fichaje, pertenece a una sede.
model Kiosco {
  id        String   @id @default(uuid()) @db.Uuid
  nombre    String
  sedeId    String   @map("sede_id") @db.Uuid
  sede      Sede     @relation(fields: [sedeId], references: [id])
  activo    Boolean  @default(true)
  // Hash (argon2) del token de dispositivo. POST /fichajes lo exige en el header
  // x-kiosco-token. Nullable: un kiosco sin token NO puede fichar hasta que un
  // administrador le genere uno. El token en claro NUNCA se almacena.
  tokenHash String?  @map("token_hash")
  creadoEn  DateTime @default(now()) @map("creado_en")

  fichajes Fichaje[]

  @@map("kiosco")
}

/// Fichaje: hecho crudo INMUTABLE (no se edita ni borra). Si fue de excepciÃģn
/// (facial fallÃģ pero el empleado se identificÃģ), queda marcado para revisiÃģn
/// del jefe. La validez la decide el jefe en `RevisionFichaje`, sin mutar esto.
model Fichaje {
  id                 String              @id @default(uuid()) @db.Uuid
  empleadoId         String              @map("empleado_id") @db.Uuid
  empleado           Empleado            @relation(fields: [empleadoId], references: [id])
  kioscoId           String              @map("kiosco_id") @db.Uuid
  kiosco             Kiosco              @relation(fields: [kioscoId], references: [id])
  tipo               TipoFichaje
  momento            DateTime            @default(now())
  esExcepcion        Boolean             @default(false) @map("es_excepcion")
  mecanismoExcepcion MecanismoExcepcion? @map("mecanismo_excepcion")
  requiereRevision   Boolean             @default(false) @map("requiere_revision")
  fotoCaptura        String?             @map("foto_captura")
  creadoEn           DateTime            @default(now()) @map("creado_en")

  revision RevisionFichaje?

  @@index([empleadoId])
  @@index([kioscoId])
  @@index([momento])
  @@map("fichaje")
}

/// RevisiÃģn del jefe sobre un fichaje de excepciÃģn. Una por fichaje; no muta el
/// Fichaje (que es inmutable): aquÃ­ se decide su validez.
model RevisionFichaje {
  id        String   @id @default(uuid()) @db.Uuid
  fichajeId String   @unique @map("fichaje_id") @db.Uuid
  fichaje   Fichaje  @relation(fields: [fichajeId], references: [id])
  jefeId    String   @map("jefe_id") @db.Uuid
  valido    Boolean
  motivo    String?
  creadoEn  DateTime @default(now()) @map("creado_en")

  @@map("revision_fichaje")
}

// âââ Asistencia Â· Motor de jornada (Fase 5) âââââââââââââââââââââââââââââââââ

/// Turno: capa CONFIGURABLE de la jornada (horario, tolerancia de tardanza,
/// pausa de respaldo, dÃ­a de descanso semanal). Lo gestiona el admin. La capa
/// legal (jornadas, recargos, topes) es FIJA y vive en el motor, no aquÃ­.
model Turno {
  id                 String   @id @default(uuid()) @db.Uuid
  empresaId          String @default(dbgenerated("NULLIF(current_setting('app.empresa_id', true), '')::uuid")) @map("empresa_id") @db.Uuid
  nombre             String
  sedeId             String?  @map("sede_id") @db.Uuid
  sede               Sede?    @relation(fields: [sedeId], references: [id])
  horaInicio         String   @map("hora_inicio")
  horaFin            String   @map("hora_fin")
  toleranciaMin      Int      @default(0) @map("tolerancia_min")
  pausaPorDefectoMin Int      @default(0) @map("pausa_por_defecto_min")
  diaDescanso        Int?     @map("dia_descanso")
  activo             Boolean  @default(true)
  creadoEn           DateTime @default(now()) @map("creado_en")

  empleados Empleado[]
  empresa Empresa? @relation(fields: [empresaId], references: [id], onDelete: Restrict)

  @@map("turno")
}

/// Jornada: interpretaciÃģn CALCULADA de los fichajes de un empleado en un dÃ­a.
/// Recalculable y sobreescribible (NO append-only); una por (empleado, fecha).
/// La fecha es la de INICIO del turno (ata los turnos que cruzan medianoche).
model Jornada {
  id                String   @id @default(uuid()) @db.Uuid
  empleadoId        String   @map("empleado_id") @db.Uuid
  empleado          Empleado @relation(fields: [empleadoId], references: [id])
  fecha             DateTime @db.Date
  minutosPresencia  Int      @default(0) @map("minutos_presencia")
  minutosPausa      Int      @default(0) @map("minutos_pausa")
  minutosTrabajados Int      @default(0) @map("minutos_trabajados")
  minutosOrdinarios Int      @default(0) @map("minutos_ordinarios")
  minutosExtra      Int      @default(0) @map("minutos_extra")
  clasificacion     String?
  recargosDetalle   Json?    @map("recargos_detalle")
  montoExtra        Decimal  @default(0) @map("monto_extra") @db.Decimal(12, 2)
  esFestivo         Boolean  @default(false) @map("es_festivo")
  anomalia          Boolean  @default(false)
  detalleAnomalia   String?  @map("detalle_anomalia")
  estado            String   @default("calculada")
  calculadaEn       DateTime @default(now()) @map("calculada_en")

  correcciones Correccion[]

  @@unique([empleadoId, fecha], map: "uq_jornada_empleado_fecha")
  @@map("jornada")
}

/// CorrecciÃģn: registro INMUTABLE y auditado de cada ajuste humano a una
/// jornada. La jornada se recalcula; estas correcciones son la huella de quiÃĐn
/// ajustÃģ quÃĐ y por quÃĐ.
model Correccion {
  id            String   @id @default(uuid()) @db.Uuid
  jornadaId     String   @map("jornada_id") @db.Uuid
  jornada       Jornada  @relation(fields: [jornadaId], references: [id])
  usuarioId     String   @map("usuario_id") @db.Uuid
  valorAnterior Json?    @map("valor_anterior")
  valorNuevo    Json?    @map("valor_nuevo")
  motivo        String
  creadoEn      DateTime @default(now()) @map("creado_en")

  @@index([jornadaId])
  @@map("correccion")
}

/// DÃ­a festivo, gestionable por el admin. Dos efectos en el motor: dispara el
/// recargo de 150% si se trabaja, y protege el dÃ­a contra descuento si no se
/// trabaja (salario fijo).
model DiaFestivo {
  id        String   @id @default(uuid()) @db.Uuid
  empresaId String @default(dbgenerated("NULLIF(current_setting('app.empresa_id', true), '')::uuid")) @map("empresa_id") @db.Uuid
  fecha     DateTime @db.Date
  nombre   String
  creadoEn DateTime @default(now()) @map("creado_en")
  empresa Empresa? @relation(fields: [empresaId], references: [id], onDelete: Restrict)

  // Fase 3 (slice): fecha UNICA POR EMPRESA (antes @unique global). Dos empresas
  // pueden declarar el mismo festivo; cada una gobierna su calendario.
  @@unique([empresaId, fecha])
  @@map("dia_festivo")
}

// âââ Asistencia Â· Cobro anticipado de horas extra (Fase 6) ââââââââââââââââââ

/// Estado de una solicitud de cobro (Modelo B): bajo el umbral nace 'aprobada'
/// (cobro directo); sobre el umbral nace 'pendiente' (espera al jefe).
enum EstadoSolicitudCobro {
  pendiente
  aprobada
  rechazada
  pagada
}

/// Saldo de horas extra por empleado. PERSISTIDO y en DINERO (no en horas). Lo
/// escribe SOLO el servicio transaccional de saldo (Fase 6.2); nunca negativo
/// (reforzado con un CHECK en Postgres). El motor de jornada acredita el monto
/// ya con recargo aplicado.
model SaldoHorasExtra {
  id            String   @id @default(uuid()) @db.Uuid
  empleadoId    String   @unique @map("empleado_id") @db.Uuid
  empleado      Empleado @relation(fields: [empleadoId], references: [id])
  saldo         Decimal  @default(0) @db.Decimal(12, 2)
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  @@map("saldo_horas_extra")
}

/// Solicitud de cobro anticipado contra el saldo. La app no mueve dinero real:
/// el admin entrega el efectivo por fuera y marca 'pagada', lo que genera el
/// Gasto en finanzas con referenciaOrigen (Fase 6.4). El `monto` ya tiene el %
/// cobrable aplicado (fracciÃģn adelantable del dinero ganado).
model SolicitudCobro {
  id            String               @id @default(uuid()) @db.Uuid
  empleadoId    String               @map("empleado_id") @db.Uuid
  empleado      Empleado             @relation(fields: [empleadoId], references: [id])
  monto         Decimal              @db.Decimal(12, 2)
  estado        EstadoSolicitudCobro @default(pendiente)
  aprobadoPorId String?              @map("aprobado_por_id") @db.Uuid
  motivoRechazo String?              @map("motivo_rechazo")
  resueltoEn    DateTime?            @map("resuelto_en")
  pagadoEn      DateTime?            @map("pagado_en")
  creadoEn      DateTime             @default(now()) @map("creado_en")

  @@index([empleadoId])
  @@index([estado])
  @@map("solicitud_cobro")
}

/// ConfiguraciÃģn ÃNICA del cobro (gestionada por el admin): porcentaje cobrable
/// (0â100, aplicado sobre el monto en dinero) y umbral del Modelo B (bajo ÃĐl, el
/// cobro es directo). Fila Ãšnica gestionada por la app.
model ConfiguracionCobro {
  id                 String   @id @default(uuid()) @db.Uuid
  empresaId          String @default(dbgenerated("NULLIF(current_setting('app.empresa_id', true), '')::uuid")) @map("empresa_id") @db.Uuid
  porcentajeCobrable Int      @default(80) @map("porcentaje_cobrable")
  umbralAprobacion   Decimal  @default(100) @map("umbral_aprobacion") @db.Decimal(12, 2)
  actualizadoEn      DateTime @updatedAt @map("actualizado_en")
  empresa Empresa? @relation(fields: [empresaId], references: [id], onDelete: Restrict)

  // Fase 3 (slice Â§7.2.4/I3): la config es la fila UNICA por empresa. El unique
  // a nivel BD lo fuerza fail-closed (una empresa no puede tener dos filas) y
  // habilita findUnique({where:{empresaId}}) en cobro.service.
  @@unique([empresaId])
  @@map("configuracion_cobro")
}
