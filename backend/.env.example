# Plantilla de variables de entorno de GestorPro (backend).
# Copiar a .env y rellenar con valores reales. El .env NUNCA se commitea.

# Conexión a PostgreSQL (Prisma). Formato:
#   postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/BASE?schema=public
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/gestorpro?schema=public"

# Puerto del servidor Fastify.
PORT=3000

# Secreto para firmar los access tokens (JWT). Generar un valor largo y
# aleatorio; nunca subir el real al repositorio. Por ejemplo, en PowerShell:
#   [Convert]::ToBase64String((1..48 | % {Get-Random -Max 256}))
JWT_ACCESS_SECRET="cambiar-por-un-secreto-largo-y-aleatorio"

# Vida del access token (formato de @fastify/jwt) y del refresh token (días).
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DIAS=30

# Orígenes permitidos para CORS (lista separada por comas). El frontend Vite
# corre por defecto en http://localhost:5173.
CORS_ORIGEN="http://localhost:5173"
