# Plantilla de variables de entorno de GestorPro (backend).
# Copiar a .env y rellenar con valores reales. El .env NUNCA se commitea.

# Conexión a PostgreSQL — DOS roles que reflejan producción (deploy/postgres):
#   - DATABASE_URL: rol de la APP en runtime, gestorpro_app (NOBYPASSRLS) → sujeto
#     a RLS multi-tenant. Lo lee src/core/prisma.ts (`npm run dev`).
#   - MIGRATOR_DATABASE_URL: rol PRIVILEGIADO gestorpro_migrador (BYPASSRLS, owner)
#     para migrate/seed (DDL, ignora RLS). Lo prefiere prisma.config.ts. La APP
#     NUNCA usa este rol. La dev DB se reconstruye con el initdb de producción
#     (deploy/postgres/initdb), que crea ambos roles. Formato:
#       postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/BASE?schema=public
DATABASE_URL="postgresql://gestorpro_app:CONTRASEÑA@localhost:5432/gestorpro?schema=public"
MIGRATOR_DATABASE_URL="postgresql://gestorpro_migrador:CONTRASEÑA@localhost:5432/gestorpro?schema=public"

# Puerto del servidor Fastify.
PORT=3000

# Secreto para firmar los access tokens (JWT). Generar un valor largo y
# aleatorio; nunca subir el real al repositorio. Por ejemplo, en PowerShell:
#   [Convert]::ToBase64String((1..48 | % {Get-Random -Max 256}))
JWT_ACCESS_SECRET="cambiar-por-un-secreto-largo-y-aleatorio"

# Vida del access token (formato de @fastify/jwt) y del refresh token (días).
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DIAS=30

# Super-admin de plataforma (Fase 4c) — OPCIONAL. Si SUPER_ADMIN_EMAIL se define, el
# seed crea/converge un Usuario con esSuperAdmin=true y SIN membresía (operador de la
# plataforma SaaS, con poder transversal sobre todos los tenants).
# ⚠️ DEBE ser un correo DEDICADO, NO una cuenta de uso diario: ese correo será
# PROMOVIDO a super-admin de plataforma. En producción, si defines el correo, la
# contraseña es OBLIGATORIA (sin default débil).
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# Orígenes permitidos para CORS (lista separada por comas). El frontend Vite
# corre por defecto en http://localhost:5173.
CORS_ORIGEN="http://localhost:5173"

# Verificador facial del fichaje. Hoy solo existe 'simulado' (NO hace biometría
# real: acepta cualquier captura). Un valor no soportado aborta el arranque.
VERIFICADOR_FACIAL="simulado"

# Riesgo aceptado mientras el verificador facial sea el simulado: marca TODO
# fichaje (incluido el facial "exitoso") para revisión del jefe. En PRODUCCIÓN
# con el simulado debe ir en "true" (ver DESPLIEGUE.md §4.2).
FICHAJE_REVISION_TOTAL="false"
